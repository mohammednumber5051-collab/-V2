rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permissive rules for testing and initial setup
    match /{document=**} {
      allow read, write: if true;
    }
    
    // Specific collection rules to be sure
    match /users/{userId} {
      allow read, write: if true;
    }
    match /dashboard_cache/{id} {
      allow read, write: if true;
    }
    match /suppliers/{id} {
      allow read, write: if true;
    }
    match /cashBoxes/{id} {
      allow read, write: if true;
    }
    match /transactions/{id} {
      allow read, write: if true;
    }
    match /quick_financial_entries/{id} {
      allow read, write: if true;
    }
    match /invoices/{id} {
      allow read, write: if true;
    }
    match /customers/{id} {
      allow read, write: if true;
    }
    match /products/{id} {
      allow read, write: if true;
    }
    match /settings/{id} {
      allow read, write: if true;
    }
    match /auditLogs/{id} {
      allow read, write: if true;
    }
  }
}
